{
	"name": "template-bot",
	"version": "0.2.0",
	"description": "Telegram bot project template",
	"imports": {
		"#root/*": "./build/src/*"
	},
	"scripts": {
		"format": "prettier",
		"typecheck": "tsc",
		"build": "tsc --noEmit false",
		"dev": "tsc-watch --onSuccess \"tsx ./src/main.ts\"",
		"start": "tsc && tsx ./src/main.ts",
		"start:force": "tsx ./src/main.ts"
	},
	"author": "mvaydev",
	"license": "MIT",
	"type": "commonjs",
	"dependencies": {
		"@grammyjs/parse-mode": "1.11.1",
		"@grammyjs/types": "3.20.0",
		"callback-data": "1.1.1",
		"dotenv": "^17.3.1",
		"grammy": "1.36.1",
		"pino": "9.9.0",
		"pino-pretty": "13.0.0",
		"tsx": "4.20.4",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@types/node": "^22.15.21",
		"prettier": "^3.8.3",
		"tsc-watch": "^6.3.1",
		"typescript": "^5.9.2"
	}
}
